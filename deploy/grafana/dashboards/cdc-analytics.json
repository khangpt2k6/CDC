{
  "uid": "cdc-analytics",
  "title": "CDC Analytics (ClickHouse)",
  "tags": ["cdc", "analytics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Live customers",
      "type": "stat",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT count() AS customers FROM cdc.customers FINAL WHERE _is_deleted = 0"
        }
      ]
    },
    {
      "id": 2,
      "title": "Live orders",
      "type": "stat",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT count() AS orders FROM cdc.orders FINAL WHERE _is_deleted = 0"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total revenue (paid)",
      "type": "stat",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT toFloat64(sum(total_amount)) AS revenue FROM cdc.orders FINAL WHERE _is_deleted = 0 AND status = 'paid'"
        }
      ]
    },
    {
      "id": 4,
      "title": "Orders over time",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 0,
          "queryType": "sql",
          "rawSql": "SELECT $__timeInterval(placed_at) AS time, count() AS orders FROM cdc.orders FINAL WHERE _is_deleted = 0 AND $__timeFilter(placed_at) GROUP BY time ORDER BY time"
        }
      ]
    },
    {
      "id": 5,
      "title": "Revenue over time (paid)",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 0,
          "queryType": "sql",
          "rawSql": "SELECT $__timeInterval(placed_at) AS time, toFloat64(sum(total_amount)) AS revenue FROM cdc.orders FINAL WHERE _is_deleted = 0 AND status = 'paid' AND $__timeFilter(placed_at) GROUP BY time ORDER BY time"
        }
      ]
    },
    {
      "id": 6,
      "title": "Orders by status",
      "type": "piechart",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT status, count() AS orders FROM cdc.orders FINAL WHERE _is_deleted = 0 GROUP BY status ORDER BY orders DESC"
        }
      ]
    },
    {
      "id": 7,
      "title": "Top customers by spend",
      "type": "table",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 13 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT c.full_name AS customer, c.country AS country, toFloat64(sum(o.total_amount)) AS spend FROM cdc.orders AS o FINAL INNER JOIN cdc.customers AS c FINAL ON o.customer_id = c.id WHERE o._is_deleted = 0 AND c._is_deleted = 0 GROUP BY customer, country ORDER BY spend DESC LIMIT 10"
        }
      ]
    },
    {
      "id": 8,
      "title": "Customers by country",
      "type": "barchart",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "cdc-clickhouse" },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT country, count() AS customers FROM cdc.customers FINAL WHERE _is_deleted = 0 GROUP BY country ORDER BY customers DESC"
        }
      ]
    }
  ]
}
