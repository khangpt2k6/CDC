{
  "uid": "cdc-pipeline-health",
  "title": "CDC Pipeline Health",
  "tags": ["cdc", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Consume throughput (events/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "sum(rate(cdc_events_consumed_total[1m]))",
          "legendFormat": "events/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Consumer lag (records)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "sum(cdc_consumer_lag) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Flush latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(cdc_flush_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(cdc_flush_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(cdc_flush_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Errors (DLQ + sink retries) /s",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "sum(rate(cdc_dlq_total[5m]))",
          "legendFormat": "dlq/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "sum(rate(cdc_sink_retries_total[5m]))",
          "legendFormat": "sink retries/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rows written /s",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "rps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "sum(rate(cdc_rows_written_total[1m]))",
          "legendFormat": "rows/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Buffered rows (backpressure)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "sum(cdc_buffered_rows)",
          "legendFormat": "buffered rows"
        }
      ]
    },
    {
      "id": 7,
      "title": "Rows written /s by worker",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "rps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "cdc-prometheus" },
          "expr": "rate(cdc_rows_written_total[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ]
}
