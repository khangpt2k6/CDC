# Local dev connection details for the docker-compose stack.
# Copy to .env if you want to source these; all values are local-only defaults.

# Kafka (host access via the PLAINTEXT_HOST listener)
KAFKA_BOOTSTRAP=localhost:29092

# Postgres
PGHOST=localhost
PGPORT=5432
PGUSER=cdc
PGPASSWORD=cdc
PGDATABASE=cdc
# DSN for the replication connection (Phase 1 uses replication=database)
DATABASE_URL=postgres://cdc:cdc@localhost:5432/cdc?sslmode=disable

# Kafka Connect (Debezium REST API)
CONNECT_REST_URL=http://localhost:8083

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=cdc

# Worker (CDC_* env vars; defaults shown — see internal/config/config.go)
# CDC_METRICS_ADDR=:9100              # host:port serving Prometheus /metrics
# CDC_DLQ_TOPIC_SUFFIX=.dlq           # appended to a source topic to form its dead-letter topic
# Backpressure / auto-resume on a slow or paused ClickHouse (Issue 2.5):
# CDC_RETRY_BASE=1s                   # first flush-retry backoff (doubles each attempt)
# CDC_RETRY_MAX=30s                   # cap on the flush-retry backoff
# CDC_CLICKHOUSE_DIAL_TIMEOUT=5s      # bound the initial connect to ClickHouse
# CDC_CLICKHOUSE_READ_TIMEOUT=30s     # bound a stalled read/write; must exceed worst legit batch latency
